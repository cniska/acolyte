{
  "name": "acolyte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "acolyte": "./src/cli.ts"
  },
  "scripts": {
    "client": "bun run src/cli.ts",
    "dev": "ACOLYTE_SERVER_RESTART=1 ACOLYTE_SET_API_URL=1 ./scripts/with-server.sh serve:env:watch bun run src/cli.ts",
    "start": "bun run client",
    "run": "bun run src/cli.ts run",
    "dogfood": "bun run src/cli.ts dogfood",
    "dogfood:smoke": "ACOLYTE_SERVER_RESTART=1 ./scripts/with-server.sh serve:env bun run scripts/dogfood-smoke.ts",
    "dogfood:progress": "bun run scripts/dogfood-progress.ts",
    "dogfood:gate": "bun run scripts/dogfood-gate.ts",
    "bench:run": "bun run scripts/run-bench.ts",
    "test:bench": "bun run scripts/run-bench.ts --runs 1 --no-warmup --json",
    "trace:lifecycle": "bun run scripts/lifecycle-trace.ts",
    "serve:env": "bun --env-file=.env run src/server.ts",
    "serve:env:watch": "bun --watch --env-file=.env run src/server.ts",
    "wait:server": "bun run src/wait-server.ts",
    "mastra:dev": "bun --env-file=.env x mastra dev --dir src/mastra",
    "studio": "./scripts/with-mastra-dev.sh",
    "format": "bunx biome format --write .",
    "lint": "bunx biome check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:tui": "bun test src/chat.tui.test.tsx src/chat-commands.tui.test.tsx src/chat-picker.tui.test.tsx",
    "test:int": "bun test src/*.int.test.ts src/*.int.test.tsx",
    "verify": "bun run format && bun run lint && bun run typecheck && bun run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:smoke": "bun run src/postgres-smoke.ts",
    "om:status": "bun run scripts/om-admin.ts status",
    "om:wipe": "bun run scripts/om-admin.ts wipe",
    "om:soak": "bun run scripts/om-soak.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@ast-grep/lang-go": "^0.0.5",
    "@ast-grep/lang-python": "^0.0.5",
    "@ast-grep/lang-rust": "^0.0.6",
    "@ast-grep/napi": "^0.41.0",
    "@mastra/core": "^1.5.0",
    "@mastra/memory": "^1.4.0",
    "@mastra/pg": "^1.5.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
