{
  "name": "acolyte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "acolyte": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts chat",
    "dev": "bash -lc 'bun run serve:env:watch >/tmp/acolyte-server.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; bun run wait:backend >/dev/null; bun run config set apiUrl http://localhost:6767 >/dev/null; bun run chat:raw'",
    "chat": "bash -lc 'bun run serve:env >/tmp/acolyte-server.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; bun run wait:backend >/dev/null; bun run config set apiUrl http://localhost:6767 >/dev/null; bun run src/cli.ts chat'",
    "chat:raw": "bun run src/cli.ts chat",
    "run": "bun run src/cli.ts run",
    "dogfood": "bun run src/cli.ts dogfood",
    "dogfood:smoke": "bun run src/dogfood-smoke.ts",
    "dogfood:smoke:env": "bash -lc 'bun run serve:env >/tmp/acolyte-server.log 2>&1 & pid=$!; trap \"kill $pid 2>/dev/null || true\" EXIT; bun run wait:backend >/dev/null; bun run dogfood:smoke'",
    "dogfood:progress": "bun run src/dogfood-progress.ts",
    "dogfood:gate": "bun run src/dogfood-gate.ts",
    "dogfood:gate:fast": "bun run src/dogfood-gate.ts --skip-verify",
    "history": "bun run src/cli.ts history",
    "status": "bun run src/cli.ts status",
    "memory": "bun run src/cli.ts memory",
    "config": "bun run src/cli.ts config",
    "tool": "bun run src/cli.ts tool",
    "serve": "bun run src/server.ts",
    "serve:watch": "bun --watch run src/server.ts",
    "serve:env": "bun --env-file=.env run src/server.ts",
    "serve:env:watch": "bun --watch --env-file=.env run src/server.ts",
    "wait:backend": "bun run src/wait-backend.ts",
    "mastra:dev": "bunx mastra dev --dir src/mastra",
    "studio": "bash -lc 'bun run mastra:dev >/tmp/acolyte-mastra-dev.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; sleep 2; bunx mastra studio'",
    "format": "bunx biome format --write .",
    "lint": "bunx biome check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "verify": "bun run format && bun run lint && bun run typecheck && bun run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:smoke": "bun run src/postgres-smoke.ts",
    "om:status": "bun run src/om-admin.ts status",
    "om:wipe": "bun run src/om-admin.ts wipe",
    "om:soak": "bun run src/om-soak.ts",
    "policy:distill": "bun run src/policy-distill.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@mastra/core": "^1.5.0",
    "@mastra/memory": "^1.4.0",
    "@mastra/pg": "^1.5.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
