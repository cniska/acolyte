{
  "name": "acolyte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "acolyte": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts chat",
    "chat": "bash -lc 'bun run serve:env >/tmp/acolyte-server.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; sleep 1; bun run config set apiUrl http://localhost:8787 >/dev/null; bun run src/cli.ts chat'",
    "chat:raw": "bun run src/cli.ts chat",
    "run": "bun run src/cli.ts run",
    "history": "bun run src/cli.ts history",
    "status": "bun run src/cli.ts status",
    "memory": "bun run src/cli.ts memory",
    "config": "bun run src/cli.ts config",
    "tool": "bun run src/cli.ts tool",
    "serve": "bun run src/server.ts",
    "serve:env": "bun --env-file=.env run src/server.ts",
    "mastra:dev": "bunx mastra dev --dir src/mastra",
    "studio": "bash -lc 'bun run mastra:dev >/tmp/acolyte-mastra-dev.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; sleep 2; bunx mastra studio'",
    "dev": "bun run src/cli.ts chat",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "verify": "bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@mastra/core": "^1.5.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
