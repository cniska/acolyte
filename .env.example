# Required for default OpenAI usage
OPENAI_API_KEY=your_openai_api_key

# Optional backend auth (client -> server)
# ACOLYTE_API_KEY=your_acolyte_api_key

# Server
# PORT=6767

# Model routing (main model is configured in ~/.acolyte/config.toml)
# ACOLYTE_MODEL_PLANNER=o3
# ACOLYTE_MODEL_CODER=gpt-5-codex
# ACOLYTE_MODEL_REVIEWER=gpt-5-mini

# Provider endpoints/keys
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Memory/storage
# DATABASE_URL=postgres://acolyte:acolyte@localhost:5432/acolyte
# ACOLYTE_OM_MODEL=gpt-5-mini
# ACOLYTE_OM_OBSERVATION_TOKENS=3000
# ACOLYTE_OM_REFLECTION_TOKENS=8000

# Permissions and context budget
# ACOLYTE_PERMISSION_MODE=read
# ACOLYTE_CONTEXT_MAX_TOKENS=8000
# ACOLYTE_MAX_HISTORY_MESSAGES=40
# ACOLYTE_MAX_MESSAGE_TOKENS=600
# ACOLYTE_MAX_ATTACHMENT_MESSAGE_TOKENS=3000
# ACOLYTE_MAX_PINNED_MESSAGE_TOKENS=1200

# Logging
# ACOLYTE_LOG_FORMAT=logfmt
